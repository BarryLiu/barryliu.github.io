---
type Props = {
  slug: string;
  variant?: 'inline' | 'compact';
};

const { slug, variant = 'compact' } = Astro.props as Props;
---

<section class:list={['post-stats', `post-stats-${variant}`]} data-post-stats data-post-stats-variant={variant} data-post-slug={slug} aria-label="文章统计">
  {variant === 'inline' ? (
    <>
      <span class="inline-stat"><span>访问</span><strong data-post-views>--</strong></span>
      <span class="inline-stat"><span>赞</span><strong data-post-likes>--</strong></span>
      <span class="inline-stat"><span>踩</span><strong data-post-dislikes>--</strong></span>
    </>
  ) : (
    <>
      <span class="stat-pill" aria-label="访问次数">
        <span>访问</span>
        <strong data-post-views>--</strong>
      </span>
      <button class="stat-pill stat-button" type="button" data-post-stat-button data-post-like aria-label="赞这篇文章">
        <span>赞</span>
        <strong data-post-likes>--</strong>
      </button>
      <button class="stat-pill stat-button" type="button" data-post-stat-button data-post-dislike aria-label="踩这篇文章">
        <span>踩</span>
        <strong data-post-dislikes>--</strong>
      </button>
    </>
  )}
</section>

<script is:inline>
  (() => {
    if (window.__flyingFishPostStatsLoaded) return;
    window.__flyingFishPostStatsLoaded = true;

    const statsRoots = () => Array.from(document.querySelectorAll('[data-post-stats]'));
    const rootsForSlug = (slug) => statsRoots().filter((root) => root.getAttribute('data-post-slug') === slug);
    const setText = (root, selector, value) => {
      const target = root.querySelector(selector);
      if (target) target.textContent = String(value ?? 0);
    };
    const updateVoteState = (slug) => {
      let liked = false;
      let disliked = false;
      try {
        liked = localStorage.getItem(`flying-fish-liked:${slug}`) === '1';
        disliked = localStorage.getItem(`flying-fish-disliked:${slug}`) === '1';
      } catch {}
      rootsForSlug(slug).forEach((root) => {
        root.querySelectorAll('[data-post-like]').forEach((button) => {
          if (liked) button.setAttribute('aria-pressed', 'true');
          else button.removeAttribute('aria-pressed');
          button.toggleAttribute('data-active', liked);
        });
        root.querySelectorAll('[data-post-dislike]').forEach((button) => {
          if (disliked) button.setAttribute('aria-pressed', 'true');
          else button.removeAttribute('aria-pressed');
          button.toggleAttribute('data-active', disliked);
        });
      });
    };
    const renderStats = (slug, data) => {
      rootsForSlug(slug).forEach((root) => {
        setText(root, '[data-post-views]', data.views);
        setText(root, '[data-post-likes]', data.likes);
        setText(root, '[data-post-dislikes]', data.dislikes);
      });
      updateVoteState(slug);
    };
    const loadStats = async (slug) => {
      const response = await fetch(`/api/post-stats?slug=${encodeURIComponent(slug)}`);
      if (!response.ok) return;
      renderStats(slug, await response.json());
    };
    const send = async (slug, action) => {
      const response = await fetch('/api/post-stats', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ slug, action }),
      });
      if (!response.ok) return;
      renderStats(slug, await response.json());
    };

    const initialize = () => {
      const slugs = new Set(statsRoots().map((root) => root.getAttribute('data-post-slug')).filter(Boolean));
      const viewedSlugs = new Set();
      slugs.forEach((slug) => {
        loadStats(slug).then(() => {
          if (viewedSlugs.has(slug)) return;
          viewedSlugs.add(slug);
          send(slug, 'view');
        });
      });

      statsRoots().forEach((root) => {
        const slug = root.getAttribute('data-post-slug');
        if (!slug) return;
        const likedKey = `flying-fish-liked:${slug}`;
        const dislikedKey = `flying-fish-disliked:${slug}`;

        root.querySelectorAll('[data-post-like]').forEach((button) => {
          button.addEventListener('click', async () => {
            try {
              if (localStorage.getItem(likedKey) === '1') return;
              localStorage.setItem(likedKey, '1');
              localStorage.removeItem(dislikedKey);
            } catch {}
            updateVoteState(slug);
            await send(slug, 'like');
          });
        });

        root.querySelectorAll('[data-post-dislike]').forEach((button) => {
          button.addEventListener('click', async () => {
            try {
              if (localStorage.getItem(dislikedKey) === '1') return;
              localStorage.setItem(dislikedKey, '1');
              localStorage.removeItem(likedKey);
            } catch {}
            updateVoteState(slug);
            await send(slug, 'dislike');
          });
        });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initialize, { once: true });
    } else {
      initialize();
    }
  })();
</script>

<style>
  .post-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: var(--color-muted);
    font-size: 0.8rem;
  }

  .post-stats-inline {
    margin-top: -4px;
  }

  .post-stats-compact {
    margin-top: 24px;
    padding-top: 18px;
    border-top: 1px solid var(--color-line);
  }

  .inline-stat,
  .stat-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 30px;
    border: 1px solid rgb(69 234 255 / 26%);
    border-radius: 999px;
    padding: 5px 10px;
    background: rgb(4 12 24 / 54%);
    box-shadow: inset 0 0 16px rgb(69 234 255 / 5%);
  }

  .inline-stat span,
  .stat-pill span {
    color: var(--color-subtle);
    font-weight: 800;
  }

  .inline-stat strong,
  .stat-pill strong {
    color: #dffbff;
    font-size: 0.9rem;
    line-height: 1;
  }

  .stat-button {
    cursor: pointer;
    font: inherit;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .stat-button:hover,
  .stat-button[data-active] {
    border-color: var(--color-cyan);
    background: rgb(26 229 255 / 14%);
    color: #f4feff;
  }

  .stat-button[data-post-dislike]:hover,
  .stat-button[data-post-dislike][data-active] {
    border-color: var(--color-magenta);
    background: rgb(255 61 242 / 12%);
  }

  @media (max-width: 620px) {
    .post-stats {
      gap: 6px;
    }

    .post-stats-compact {
      margin-top: 20px;
    }
  }
</style>
