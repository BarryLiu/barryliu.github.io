---
import { site } from '../data/site';

const { postCount = 0 } = Astro.props;
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy hero-card">
      <p class="hero-eyebrow" data-i18n-zh="赛博水族馆 / AI 工程博客 / 默认中文" data-i18n-en="Cyber Aquarium / AI Engineering Blog / EN Ready"><span></span>赛博水族馆 / AI 工程博客 / 默认中文</p>
      <h1 data-i18n-html data-i18n-zh="一条想飞的鱼，<br />把深海写成天空。" data-i18n-en="A flying fish,<br />turning deep water into sky.">一条想飞的鱼，<br />把深海写成天空。</h1>
      <p
        class="hero-desc"
        data-i18n-zh="这里不是普通文章列表，而是我的 AI 工程实验舱：记录智能体、RAG、多模态、工程自动化与长期学习路线。你可以从项目入口查看实践成果，也可以通过 GitHub 或邮箱联系我。"
        data-i18n-en="This is not a plain archive. It is my AI engineering cockpit for agents, RAG, multimodal systems, automation, and long-term learning paths. Start from projects, then dive into the notes."
      >
        这里不是普通文章列表，而是我的 AI 工程实验舱：记录智能体、RAG、多模态、工程自动化与长期学习路线。你可以从项目入口查看实践成果，也可以通过 GitHub 或邮箱联系我。
      </p>
      <div class="button-row">
        <a class="button primary" href="#projects" data-i18n-zh="查看项目" data-i18n-en="View projects">查看项目</a>
        <a class="button" href="/archive/" data-search-open data-i18n-zh="全局搜索" data-i18n-en="Global search">全局搜索</a>
        <a class="button" href={site.github} data-i18n-zh="GitHub 主页" data-i18n-en="GitHub">GitHub 主页</a>
      </div>
      <div class="signals" aria-label="站点统计">
        <div>
          <strong>{postCount}+</strong>
          <span data-i18n-zh="技术文章与笔记" data-i18n-en="technical posts">技术文章与笔记</span>
        </div>
        <div>
          <strong>AI</strong>
          <span data-i18n-zh="主线专题更新中" data-i18n-en="main track in progress">主线专题更新中</span>
        </div>
        <div>
          <strong>构建</strong>
          <span data-i18n-zh="项目驱动学习" data-i18n-en="project-led learning">项目驱动学习</span>
        </div>
      </div>
    </div>
    <div class="aquarium" aria-label="Flying fish holographic aquarium">
      <div class="aqua-glow"></div>
      <div class="ring ring-a"></div>
      <div class="ring ring-b"></div>
      <div class="ring ring-c"></div>
      <svg class="fish" viewBox="0 0 340 220" role="img" aria-label="飞鱼标识">
        <path class="fish-wing" d="M80 130C122 30 230 12 298 36C238 64 199 109 190 186C154 150 122 132 80 130Z" />
        <path class="fish-body" d="M38 126C92 72 185 62 244 122C188 190 96 184 38 126Z" />
        <path class="fish-tail" d="M238 121L318 72L294 126L320 174L238 146Z" />
        <circle cx="104" cy="116" r="9" />
      </svg>
      <div class="node node-rag">RAG<br />Core</div>
      <div class="node node-agent">Agent<br />Ops</div>
      <div class="node node-mlops">MLOps<br />Dock</div>
      <div class="node node-code">Code<br />Tools</div>
      <div class="hud">
        <span data-i18n-zh="markdown -> blog -> project radar" data-i18n-en="markdown -> blog -> project radar">markdown -> blog -> project radar</span>
        <strong>ASCENDING</strong>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 824px;
    padding: 40px 0 34px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 746px) minmax(360px, 526px);
    gap: 40px;
    align-items: center;
  }

  .hero-copy {
    display: grid;
    gap: 25px;
    min-height: 650px;
    align-content: center;
  }

  .hero-card {
    border: 1px solid rgb(40 247 255 / 20%);
    border-radius: 34px;
    padding: 44px 40px;
    background:
      linear-gradient(135deg, rgb(40 247 255 / 13%), rgb(8 16 31 / 78%) 42%, rgb(255 71 223 / 10%)),
      rgb(8 16 31 / 78%);
    box-shadow: 0 30px 80px rgb(0 0 0 / 38%), var(--shadow-glow);
  }

  .hero-eyebrow {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 9px;
    border: 1px solid rgb(40 247 255 / 32%);
    border-radius: 999px;
    margin: 0;
    padding: 8px 12px;
    background: rgb(8 47 73 / 20%);
    color: var(--color-cyan);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .hero-eyebrow span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-lime);
    box-shadow: 0 0 18px var(--color-lime);
  }

  h1 {
    margin: 0;
    max-width: 760px;
    color: #fff;
    background: linear-gradient(90deg, #fff 0%, var(--color-cyan) 46%, var(--color-magenta) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    font-size: clamp(4rem, 6.4vw, 4.75rem);
    line-height: 1.03;
    letter-spacing: 0;
    -webkit-text-fill-color: transparent;
  }

  .hero-desc {
    max-width: 680px;
    margin: 0;
    color: #b8c7d2;
    font-size: 1.06rem;
  }

  .signals {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    max-width: 640px;
  }

  .signals div {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    padding: 15px;
    background: rgb(14 24 49 / 60%);
  }

  .signals strong {
    display: block;
    color: var(--color-text);
    font-size: 1.8rem;
    line-height: 1;
  }

  .signals div:nth-child(2) strong {
    color: var(--color-cyan);
  }

  .signals div:nth-child(3) strong {
    color: var(--color-lime);
  }

  .signals span {
    color: var(--color-muted);
    font-size: 0.76rem;
  }

  .aquarium {
    position: relative;
    min-height: 650px;
    overflow: hidden;
    border: 1px solid rgb(40 247 255 / 26%);
    border-radius: 30px;
    background:
      linear-gradient(90deg, rgb(40 247 255 / 12%) 1px, transparent 1px),
      linear-gradient(0deg, rgb(40 247 255 / 10%) 1px, transparent 1px),
      rgb(2 6 23 / 36%);
    background-size: 44px 44px;
    box-shadow: inset 0 0 80px rgb(40 247 255 / 10%), 0 0 80px rgb(255 71 223 / 12%);
  }

  .aqua-glow {
    position: absolute;
    inset: 124px 73px auto;
    width: 380px;
    height: 380px;
    border-radius: 50%;
    background: radial-gradient(circle, rgb(255 71 223 / 24%), rgb(40 247 255 / 12%) 36%, transparent 70%);
    filter: blur(4px);
  }

  .ring {
    position: absolute;
    top: 58px;
    left: 48px;
    width: 430px;
    height: 430px;
    border: 1px solid rgb(40 247 255 / 34%);
    border-radius: 50%;
  }

  .ring-b {
    top: 98px;
    left: 76px;
    width: 372px;
    height: 318px;
    border-color: rgb(255 71 223 / 35%);
    transform: rotate(18deg);
  }

  .ring-c {
    top: 148px;
    left: 120px;
    width: 284px;
    height: 230px;
    border-color: rgb(185 255 74 / 32%);
    transform: rotate(-22deg);
  }

  .fish {
    position: absolute;
    top: 192px;
    left: 98px;
    width: 330px;
    filter: drop-shadow(0 0 28px rgb(40 247 255 / 55%));
  }

  .fish path {
    fill: none;
    stroke-linejoin: round;
    stroke-width: 10;
  }

  .fish-wing {
    stroke: var(--color-lime);
  }

  .fish-body {
    stroke: var(--color-cyan);
  }

  .fish-tail {
    stroke: var(--color-magenta);
  }

  .fish circle {
    fill: #fff;
  }

  .node {
    position: absolute;
    display: grid;
    width: 76px;
    height: 76px;
    place-items: center;
    border: 1px solid rgb(255 255 255 / 18%);
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-cyan), var(--color-lime));
    color: #06111f;
    font-size: 0.78rem;
    font-weight: 900;
    line-height: 1.2;
    text-align: center;
  }

  .node-rag {
    top: 58px;
    left: 56px;
  }

  .node-agent {
    top: 104px;
    right: 60px;
  }

  .node-mlops {
    right: 90px;
    bottom: 114px;
  }

  .node-code {
    bottom: 98px;
    left: 76px;
  }

  .hud {
    position: absolute;
    right: 24px;
    bottom: 24px;
    left: 24px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    background: rgb(2 6 23 / 72%);
    color: #c7f9ff;
    font-size: 0.8rem;
  }

  .hud strong {
    color: var(--color-lime);
  }

  @media (max-width: 980px) {
    .hero {
      padding-top: 58px;
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-card {
      padding: 32px 26px;
    }

    .aquarium {
      min-height: 480px;
      border-radius: var(--radius-lg);
    }

    .aqua-glow,
    .ring,
    .ring-b,
    .ring-c,
    .fish {
      transform: scale(0.8);
      transform-origin: top left;
    }
  }

  @media (max-width: 560px) {
    .signals {
      grid-template-columns: 1fr;
    }

    .aquarium {
      min-height: 360px;
    }

    .node {
      width: 62px;
      height: 62px;
      font-size: 0.68rem;
    }

    .hud {
      display: none;
    }
  }
</style>
