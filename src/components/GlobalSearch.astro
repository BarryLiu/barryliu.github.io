---
const { compact = false } = Astro.props;
---

<div class:list={['global-search', { compact }]} data-search-root>
  <a
    class="search-trigger"
    href="/archive/"
    data-search-open
    data-i18n-aria-label-zh="打开全局搜索"
    data-i18n-aria-label-en="Open global search"
    aria-label="打开全局搜索"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M10.8 4.2a6.6 6.6 0 1 1 0 13.2a6.6 6.6 0 0 1 0-13.2Zm0 2a4.6 4.6 0 1 0 0 9.2a4.6 4.6 0 0 0 0-9.2Zm5.18 9.16l4.1 4.1l-1.42 1.42l-4.1-4.1l1.42-1.42Z" />
    </svg>
    <span data-i18n-zh="全局搜索" data-i18n-en="Search">全局搜索</span>
    <kbd>⌘K</kbd>
  </a>

  <div class="search-dialog" id="global-search-dialog" role="dialog" aria-modal="true" aria-labelledby="global-search-title" data-search-dialog hidden>
    <button class="search-backdrop" type="button" data-search-close aria-label="关闭搜索"></button>
    <section class="search-panel">
      <div class="search-console-head">
        <div>
          <p data-i18n-zh="全站检索控制台" data-i18n-en="Global Search Console">全站检索控制台</p>
          <h2 id="global-search-title" data-i18n-zh="搜索文章、标签、项目线索" data-i18n-en="Search posts, tags, and project signals">搜索文章、标签、项目线索</h2>
        </div>
        <button class="close-button" type="button" data-search-close data-i18n-aria-label-zh="关闭搜索" data-i18n-aria-label-en="Close search" aria-label="关闭搜索">×</button>
      </div>
      <label class="search-box">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M10.8 4.2a6.6 6.6 0 1 1 0 13.2a6.6 6.6 0 0 1 0-13.2Zm0 2a4.6 4.6 0 1 0 0 9.2a4.6 4.6 0 0 0 0-9.2Zm5.18 9.16l4.1 4.1l-1.42 1.42l-4.1-4.1l1.42-1.42Z" />
        </svg>
        <input
          type="search"
          data-search-input
          autocomplete="off"
          spellcheck="false"
          placeholder="输入关键词，例如 RAG、Docker、签名工具"
          data-i18n-placeholder-zh="输入关键词，例如 RAG、Docker、签名工具"
          data-i18n-placeholder-en="Type keywords such as RAG, Docker, signing tool"
        />
      </label>
      <div class="search-meta">
        <span data-search-count data-i18n-zh="加载搜索索引中" data-i18n-en="Loading search index">加载搜索索引中</span>
        <span data-i18n-zh="Enter 打开第一条 / Esc 关闭" data-i18n-en="Enter opens first result / Esc closes">Enter 打开第一条 / Esc 关闭</span>
      </div>
      <div class="search-results" data-search-results></div>
    </section>
  </div>
</div>

<script is:inline>
  (() => {
    if (window.__flyingFishSearchLoaded) return;
    window.__flyingFishSearchLoaded = true;

    let indexPromise;
    let searchIndex = [];
    let activeDialog = null;
    let activeInput = null;
    let firstResultUrl = '';

    const strings = {
      zh: {
        loading: '加载搜索索引中',
        ready: (count) => `已索引 ${count} 篇文章`,
        empty: '输入关键词开始检索文章标题、摘要、分类、标签和正文片段。',
        none: '没有匹配结果，试试 RAG、AI、Docker、签名、Python 等关键词。',
        error: '搜索索引加载失败，请先前往归档页浏览。',
        tag: '标签',
        category: '分类',
      },
      en: {
        loading: 'Loading search index',
        ready: (count) => `${count} posts indexed`,
        empty: 'Type a keyword to search titles, summaries, categories, tags, and post excerpts.',
        none: 'No matches yet. Try RAG, AI, Docker, signing, or Python.',
        error: 'Search index failed to load. Use the archive page as a fallback.',
        tag: 'Tags',
        category: 'Category',
      },
    };

    const getLang = () => document.documentElement.dataset.lang === 'en' ? 'en' : 'zh';
    const t = (key, ...args) => {
      const value = strings[getLang()][key];
      return typeof value === 'function' ? value(...args) : value;
    };

    const escapeHtml = (value = '') => value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char]);

    const loadIndex = async () => {
      if (!indexPromise) {
        indexPromise = fetch('/search.json')
          .then((response) => {
            if (!response.ok) throw new Error(`Search index ${response.status}`);
            return response.json();
          })
          .then((items) => {
            searchIndex = items.map((item) => ({
              ...item,
              haystack: [
                item.title,
                item.description,
                item.category,
                ...(item.categories ?? []),
                ...(item.tags ?? []),
                item.text,
              ].join(' ').toLowerCase(),
            }));
            return searchIndex;
          });
      }
      return indexPromise;
    };

    const setCount = (message) => {
      document.querySelectorAll('[data-search-count]').forEach((node) => {
        node.textContent = message;
      });
    };

    const emptyState = (message) => `<div class="search-empty">${escapeHtml(message)}</div>`;

    const scoreItem = (item, tokens) => {
      if (!tokens.every((token) => item.haystack.includes(token))) return 0;
      let score = 1;
      const title = item.title.toLowerCase();
      const description = (item.description ?? '').toLowerCase();
      for (const token of tokens) {
        if (title.includes(token)) score += 8;
        if ((item.tags ?? []).some((tag) => tag.toLowerCase().includes(token))) score += 5;
        if ((item.categories ?? []).some((category) => category.toLowerCase().includes(token))) score += 4;
        if (description.includes(token)) score += 2;
      }
      return score;
    };

    const renderResults = (items) => {
      const results = document.querySelector('[data-search-results]');
      if (!results) return;
      firstResultUrl = items[0]?.url ?? '';
      if (!items.length) {
        results.innerHTML = emptyState(t('none'));
        return;
      }
      results.innerHTML = items.slice(0, 9).map((item) => `
        <a class="search-result" href="${escapeHtml(item.url)}">
          <span class="search-result-date">${escapeHtml(item.date)}</span>
          <strong>${escapeHtml(item.title)}</strong>
          <small>${escapeHtml(item.description || item.text.slice(0, 120))}</small>
          <em>${escapeHtml(t('category'))}: ${escapeHtml(item.category)} · ${escapeHtml(t('tag'))}: ${escapeHtml((item.tags ?? []).slice(0, 3).join(' / ') || '-')}</em>
        </a>
      `).join('');
    };

    const runSearch = () => {
      const query = (activeInput?.value ?? '').trim().toLowerCase();
      const results = document.querySelector('[data-search-results]');
      if (!results) return;
      if (!query) {
        firstResultUrl = '';
        results.innerHTML = emptyState(t('empty'));
        return;
      }
      const tokens = query.split(/\s+/).filter(Boolean);
      const matches = searchIndex
        .map((item) => ({ item, score: scoreItem(item, tokens) }))
        .filter(({ score }) => score > 0)
        .sort((a, b) => b.score - a.score || b.item.date.localeCompare(a.item.date))
        .map(({ item }) => item);
      renderResults(matches);
    };

    const openDialog = async (event) => {
      event?.preventDefault();
      activeDialog = document.querySelector('[data-search-dialog]');
      activeInput = document.querySelector('[data-search-input]');
      if (!activeDialog || !activeInput) return;
      if (activeDialog.parentElement !== document.body) {
        document.body.appendChild(activeDialog);
      }
      activeDialog.hidden = false;
      document.body.classList.add('search-open');
      activeInput.focus();
      setCount(t('loading'));
      document.querySelector('[data-search-results]').innerHTML = emptyState(t('empty'));
      try {
        const items = await loadIndex();
        setCount(t('ready', items.length));
        runSearch();
      } catch {
        setCount(t('error'));
        document.querySelector('[data-search-results]').innerHTML = emptyState(t('error'));
      }
    };

    const closeDialog = () => {
      if (!activeDialog) activeDialog = document.querySelector('[data-search-dialog]');
      if (!activeDialog) return;
      activeDialog.hidden = true;
      document.body.classList.remove('search-open');
    };

    document.addEventListener('click', (event) => {
      const open = event.target.closest('[data-search-open]');
      if (open) {
        openDialog(event);
        return;
      }
      if (event.target.closest('[data-search-close]')) closeDialog();
    });

    document.addEventListener('input', (event) => {
      if (!event.target.matches('[data-search-input]')) return;
      activeInput = event.target;
      runSearch();
    });

    document.addEventListener('keydown', (event) => {
      const key = event.key.toLowerCase();
      if ((event.metaKey || event.ctrlKey) && key === 'k') {
        openDialog(event);
        return;
      }
      if (key === 'escape') closeDialog();
      if (key === 'enter' && document.activeElement?.matches('[data-search-input]') && firstResultUrl) {
        window.location.href = firstResultUrl;
      }
    });

    window.addEventListener('flying-fish:lang', () => {
      if (!activeDialog || activeDialog.hidden) return;
      setCount(searchIndex.length ? t('ready', searchIndex.length) : t('loading'));
      runSearch();
    });
  })();
</script>

<style>
  .global-search {
    display: inline-flex;
  }

  .search-trigger {
    display: inline-flex;
    height: 40px;
    align-items: center;
    gap: 8px;
    border: 1px solid rgb(40 247 255 / 30%);
    border-radius: 999px;
    padding: 0 12px;
    background: rgb(14 24 49 / 72%);
    color: #dffbff;
    font-size: 0.82rem;
    font-weight: 900;
  }

  .search-trigger:hover {
    border-color: rgb(40 247 255 / 66%);
    box-shadow: 0 0 24px rgb(40 247 255 / 16%);
  }

  svg {
    width: 17px;
    height: 17px;
    fill: currentColor;
  }

  kbd {
    border: 1px solid rgb(255 255 255 / 16%);
    border-radius: 6px;
    padding: 2px 5px;
    background: rgb(2 6 23 / 75%);
    color: var(--color-lime);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .search-dialog[hidden] {
    display: none;
  }

  .search-dialog {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: grid;
    place-items: start center;
    padding: 120px 20px 40px;
  }

  .search-backdrop {
    position: fixed;
    inset: 0;
    cursor: pointer;
    border: 0;
    background:
      radial-gradient(circle at 20% 0%, rgb(40 247 255 / 16%), transparent 34rem),
      radial-gradient(circle at 90% 12%, rgb(255 71 223 / 16%), transparent 32rem),
      rgb(2 6 23 / 78%);
    backdrop-filter: blur(18px);
  }

  .search-panel {
    position: relative;
    z-index: 1;
    display: grid;
    width: min(820px, calc(100vw - 40px));
    max-height: min(720px, calc(100vh - 150px));
    overflow: hidden;
    border: 1px solid rgb(40 247 255 / 36%);
    border-radius: 28px;
    background:
      linear-gradient(90deg, rgb(40 247 255 / 10%) 1px, transparent 1px),
      linear-gradient(0deg, rgb(40 247 255 / 8%) 1px, transparent 1px),
      linear-gradient(135deg, rgb(14 24 49 / 96%), rgb(3 4 11 / 96%));
    background-size: 44px 44px, 44px 44px, auto;
    box-shadow: 0 28px 90px rgb(0 0 0 / 58%), var(--shadow-glow);
  }

  .search-console-head {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    border-bottom: 1px solid var(--color-line);
    padding: 24px 26px 18px;
  }

  .search-console-head p {
    margin: 0 0 5px;
    color: var(--color-magenta);
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .search-console-head h2 {
    margin: 0;
    color: #f0fdff;
    font-size: clamp(1.4rem, 4vw, 2rem);
    line-height: 1.2;
  }

  .close-button {
    display: grid;
    width: 40px;
    height: 40px;
    flex: 0 0 auto;
    cursor: pointer;
    place-items: center;
    border: 1px solid var(--color-line);
    border-radius: 50%;
    background: rgb(2 6 23 / 72%);
    color: #dffbff;
    font-size: 1.5rem;
  }

  .search-box {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 22px 26px 10px;
    border: 1px solid rgb(185 255 74 / 30%);
    border-radius: 999px;
    padding: 0 18px;
    background: rgb(2 6 23 / 72%);
  }

  .search-box input {
    width: 100%;
    min-height: 54px;
    border: 0;
    outline: 0;
    background: transparent;
    color: #f0fdff;
    font: inherit;
    font-size: 1rem;
  }

  .search-box input::placeholder {
    color: #60788d;
  }

  .search-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px;
    padding: 0 28px 16px;
    color: var(--color-subtle);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .search-results {
    display: grid;
    gap: 10px;
    overflow: auto;
    padding: 0 26px 26px;
  }

  .search-result,
  .search-empty {
    border: 1px solid var(--color-line);
    border-radius: 18px;
    padding: 14px 16px;
    background: rgb(9 20 36 / 70%);
  }

  .search-result {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 4px 12px;
  }

  .search-result-date {
    grid-row: 1 / span 3;
    color: var(--color-lime);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 900;
  }

  .search-result strong {
    color: #f0fdff;
    line-height: 1.3;
  }

  .search-result small {
    color: #aebdca;
    line-height: 1.5;
  }

  .search-result em {
    color: var(--color-subtle);
    font-size: 0.76rem;
    font-style: normal;
    font-weight: 800;
  }

  .search-empty {
    color: var(--color-muted);
  }

  @media (max-width: 760px) {
    .search-trigger {
      width: 100%;
      justify-content: space-between;
    }

    .search-dialog {
      padding-top: 78px;
    }

    .search-panel {
      max-height: calc(100vh - 96px);
      border-radius: 22px;
    }

    .search-result {
      grid-template-columns: 1fr;
    }

    .search-result-date {
      grid-row: auto;
    }
  }
</style>
