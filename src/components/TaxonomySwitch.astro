---
const { title, titleEn = title, hrefPrefix, items } = Astro.props as {
  title: string;
  titleEn?: string;
  hrefPrefix: string;
  items: { name: string; slug: string; count: number }[];
};
---

<section class="taxonomy">
  <h2 data-i18n-zh={title} data-i18n-en={titleEn}>{title}</h2>
  <div>
    {items.map((item) => (
      <a href={`/${hrefPrefix}/${item.slug}/`}>
        <span>{item.name}</span>
        <strong>{item.count}</strong>
      </a>
    ))}
  </div>
</section>

<style>
  .taxonomy {
    display: grid;
    gap: 16px;
  }

  h2 {
    margin: 0;
    color: var(--color-text);
    font-size: 1.1rem;
  }

  div {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 8px 12px;
    background: rgb(2 6 23 / 54%);
  }

  span {
    color: #dffbff;
    font-size: 0.88rem;
    font-weight: 700;
  }

  strong {
    color: var(--color-lime);
    font-size: 0.82rem;
  }
</style>
