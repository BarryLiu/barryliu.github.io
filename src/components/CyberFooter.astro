---
import CyberLogo from './CyberLogo.astro';
import { site } from '../data/site';
---

<footer class="footer">
  <div class="container footer-inner">
    <CyberLogo compact />
    <p data-i18n-zh={`${site.subtitle}。Markdown 内容站，Astro 静态生成。`} data-i18n-en={`${site.subtitleEn}. Markdown-first static site generated by Astro.`}>
      {site.subtitle}。Markdown 内容站，Astro 静态生成。
    </p>
    <nav aria-label="页脚导航">
      {site.nav.map((item) => <a href={item.href} data-i18n-zh={item.label} data-i18n-en={item.labelEn}>{item.label}</a>)}
      <a href="/rss.xml">RSS</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-line);
    padding: 36px 0;
    background: rgb(2 6 23 / 68%);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: auto minmax(220px, 1fr) auto;
    gap: 20px;
    align-items: center;
  }

  p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: flex-end;
  }

  a {
    color: #c6d6e1;
    font-size: 0.88rem;
    font-weight: 700;
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }

    nav {
      justify-content: flex-start;
    }
  }
</style>
