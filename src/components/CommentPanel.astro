---
import { site } from '../data/site';

const comments = site.comments;
const commentsEnabled =
  comments?.enabled === true &&
  comments.provider === 'giscus' &&
  Boolean(comments.repo) &&
  Boolean(comments.repoId) &&
  Boolean(comments.category) &&
  Boolean(comments.categoryId);
---

<section class="comments" aria-labelledby="comments-title">
  <h2 id="comments-title">讨论与反馈</h2>
  {commentsEnabled ? (
    <div class="comment-widget">
      <script
        src="https://giscus.app/client.js"
        data-repo={comments.repo}
        data-repo-id={comments.repoId}
        data-category={comments.category}
        data-category-id={comments.categoryId}
        data-mapping={comments.mapping}
        data-strict={comments.strict}
        data-reactions-enabled={comments.reactionsEnabled}
        data-emit-metadata={comments.emitMetadata}
        data-input-position={comments.inputPosition}
        data-theme={comments.theme}
        data-lang={comments.lang}
        crossorigin="anonymous"
        async
      ></script>
    </div>
  ) : (
    <>
      <p>评论系统暂未启用，可先通过 GitHub 或邮箱交流。</p>
      <div class="button-row">
        <a class="button" href={site.github}>GitHub</a>
        <a class="button primary" href={`mailto:${site.email}`}>邮箱联系</a>
      </div>
    </>
  )}
</section>

<script is:inline>
  // 恢复滚动位置（Giscus 登录授权后会刷新页面）
  if ('scrollRestoration' in history) {
    history.scrollRestoration = 'manual';
  }
  const savedScroll = sessionStorage.getItem('giscus-scroll');
  if (savedScroll !== null) {
    sessionStorage.removeItem('giscus-scroll');
    setTimeout(() => window.scrollTo(0, parseInt(savedScroll, 10)), 100);
  }
  window.addEventListener('beforeunload', () => {
    sessionStorage.setItem('giscus-scroll', String(window.scrollY));
  });
</script>

<style>
  .comments {
    display: grid;
    gap: 14px;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    margin-top: 42px;
    padding: 22px;
    background: rgb(9 20 36 / 62%);
  }

  h2,
  p {
    margin: 0;
  }

  p {
    color: var(--color-muted);
  }

  .comment-widget {
    min-height: 180px;
  }
</style>
