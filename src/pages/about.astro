---
import { site } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于" description="关于想飞的鱼和这个技术博客">
  <section class="section container about">
    <div>
      <p class="eyebrow">About</p>
      <h1 class="section-title">想飞的鱼</h1>
      <p class="lead">这里记录我对 AI 工程、自动化工具、软件开发和长期学习路线的持续整理。新站点使用 Astro 重构，保留旧 Markdown 内容，同时把项目、文章、分类和标签连接成更清晰的技术地图。</p>
      <div class="button-row">
        <a class="button primary" href={site.github}>GitHub</a>
        <a class="button" href={`mailto:${site.email}`}>邮箱联系</a>
      </div>
    </div>
    <dl>
      <div>
        <dt>站点定位</dt>
        <dd>个人技术实验室与知识库</dd>
      </div>
      <div>
        <dt>内容主线</dt>
        <dd>AI、RAG、Agent、工程自动化、开发工具</dd>
      </div>
      <div>
        <dt>构建方式</dt>
        <dd>Astro 静态输出，GitHub Pages 发布</dd>
      </div>
    </dl>
  </section>
</BaseLayout>

<style>
  .about {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.55fr);
    gap: 48px;
    align-items: start;
    min-height: 68vh;
  }

  .lead {
    max-width: 760px;
    margin: 22px 0;
    color: #b8c7d2;
    font-size: 1.08rem;
  }

  dl {
    display: grid;
    gap: 14px;
    margin: 0;
  }

  dl div {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    padding: 18px;
    background: rgb(9 20 36 / 64%);
  }

  dt {
    color: var(--color-cyan);
    font-size: 0.78rem;
    font-weight: 800;
  }

  dd {
    margin: 8px 0 0;
    color: #dffbff;
  }

  @media (max-width: 820px) {
    .about {
      grid-template-columns: 1fr;
    }
  }
</style>
