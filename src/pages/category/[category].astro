---
import PostCard from '../../components/PostCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts, getTaxonomyCounts, postsWithTaxonomy, type Post } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return getTaxonomyCounts(posts, 'categories').map((category) => ({
    params: { category: category.slug },
    props: { name: category.name, posts: postsWithTaxonomy(posts, 'categories', category.slug) },
  }));
}

const { name, posts } = Astro.props as { name: string; posts: Post[] };
---

<BaseLayout title={`分类：${name}`} description={`分类 ${name} 下的文章`}>
  <section class="section container">
    <div class="section-header">
      <div>
        <p class="eyebrow">Category</p>
        <h1 class="section-title">{name}</h1>
      </div>
      <p class="section-desc">共 {posts.length} 篇文章。</p>
    </div>
    <div class="grid three">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
